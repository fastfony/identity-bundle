{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .ff-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 90vh;
            background-color: #f9fafb;
            color: #111827;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            padding: 1rem;
        }
        .ff-card {
            background-color: #ffffff;
            border-radius: 0.75rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 28rem;
        }
        .ff-title {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            text-align: center;
            margin-bottom: 2rem;
            color: #111827;
        }
        .ff-form-group {
            margin-bottom: 1.25rem;
        }
        .ff-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.375rem;
        }
        .ff-input {
            width: 100%;
            padding: 0.625rem 0.875rem;
            border: 1px solid #d1d5db;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            line-height: 1.25rem;
            color: #111827;
            background-color: #ffffff;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out, background-color 0.15s ease-in-out;
            box-sizing: border-box;
        }
        .ff-input:hover {
            border-color: #9ca3af;
        }
        .ff-input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px #ffffff, 0 0 0 4px #3b82f6;
        }
        .ff-btn {
            display: block;
            width: 100%;
            padding: 0.625rem 1.25rem;
            background-color: #2563eb;
            color: #ffffff;
            font-weight: 600;
            font-size: 0.875rem;
            text-align: center;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            margin-top: 1.75rem;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }
        .ff-btn:hover {
            background-color: #1d4ed8;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transform: translateY(-1px);
        }
        .ff-btn:focus {
            outline: none;
            box-shadow: 0 0 0 2px #ffffff, 0 0 0 4px #2563eb;
        }
        .ff-link {
            color: #2563eb;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.15s ease-in-out;
        }
        .ff-link:hover {
            color: #1e3a8a;
            text-decoration: underline;
        }
        .ff-alert {
            background-color: #fee2e2;
            color: #b91c1c;
            padding: 0.75rem;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            margin-bottom: 1rem;
        }
        .ff-links-group {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
        }
        .ff-footer {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.875rem;
            color: #6b7280;
        }
        .ff-footer-top {
            margin-top: 0;
            margin-bottom: 1.5rem;
            text-align: center;
            font-size: 0.875rem;
            color: #6b7280;
        }
        .ff-form-error {
            color: #b91c1c;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .ff-title-with-back {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .ff-back-link {
            position: absolute;
            left: 0;
            display: flex;
            align-items: center;
            color: #2563eb;
        }
        .ff-back-link:hover {
            color: #1d4ed8;
        }
        .ff-success-container {
            text-align: center;
        }
        .ff-success-icon {
            color: #10b981;
            display: flex;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .ff-text-sm {
            font-size: 0.875rem;
        }
        .ff-text-muted {
            font-size: 0.875rem;
            color: #6b7280;
            margin-top: 1rem;
        }
        .ff-checkbox-group {
            display: flex;
            align-items: center;
            gap: 0.625rem;
            margin-top: 1.25rem;
        }
        .ff-checkbox-input {
            width: 1.125rem;
            height: 1.125rem;
            cursor: pointer;
            flex-shrink: 0;
            border-radius: 0.25rem;
            border: 1px solid #d1d5db;
            color: #2563eb;
            transition: all 0.15s ease-in-out;
        }
        .ff-checkbox-input:focus {
            outline: none;
            box-shadow: 0 0 0 2px #ffffff, 0 0 0 4px #3b82f6;
        }
        .ff-checkbox-label {
            margin-bottom: 0;
            font-size: 0.875rem;
            cursor: pointer;
            color: #374151;
            user-select: none;
        }
        .ff-links-group-start {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            margin-bottom: 1.5rem;
        }

        @media (prefers-color-scheme: dark) {
            .ff-wrapper {
                background-color: #111827;
                color: #f9fafb;
            }
            .ff-card {
                background-color: #1f2937;
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -4px rgba(0, 0, 0, 0.3);
            }
            .ff-title {
                color: #f9fafb;
            }
            .ff-label {
                color: #e5e7eb;
            }
            .ff-input {
                background-color: #374151;
                border-color: #4b5563;
                color: #f9fafb;
            }
            .ff-input:hover {
                border-color: #6b7280;
                background-color: #4b5563;
            }
            .ff-input:focus {
                border-color: #60a5fa;
                box-shadow: 0 0 0 2px #1f2937, 0 0 0 4px #60a5fa;
            }
            .ff-link {
                color: #60a5fa;
            }
            .ff-link:hover {
                color: #93c5fd;
            }
            .ff-btn {
                background-color: #3b82f6;
            }
            .ff-btn:hover {
                background-color: #2563eb;
            }
            .ff-btn:focus {
                box-shadow: 0 0 0 2px #1f2937, 0 0 0 4px #3b82f6;
            }
            .ff-alert {
                background-color: #7f1d1d;
                color: #fca5a5;
                border: 1px solid #991b1b;
            }
            .ff-footer, .ff-footer-top, .ff-text-muted {
                color: #9ca3af;
            }
            .ff-form-error {
                color: #fca5a5;
            }
            .ff-checkbox-label {
                color: #e5e7eb;
            }
            .ff-checkbox-input {
                background-color: #374151;
                border-color: #4b5563;
            }
            .ff-checkbox-input:focus {
                box-shadow: 0 0 0 2px #1f2937, 0 0 0 4px #60a5fa;
            }
        }
    </style>
{% endblock %}